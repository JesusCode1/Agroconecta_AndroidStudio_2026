<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="150dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true"
    android:layout_margin="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">



        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgProshap"
            android:layout_width="150dp"
            android:layout_height="130dp"
            android:layout_gravity="center"
            android:src="@drawable/img_item"
            android:layout_marginTop="2dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/item_nombrepro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/item_nombrepro"
                android:textSize="18sp"
                android:textColor="#2D3436"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/item_preciopro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_preciopro"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / Kg"
                    android:textSize="12sp"
                    android:textColor="#636E72"/>
            </LinearLayout>
            <TextView
                android:id="@+id/item_stockpro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock: 00"
                android:textSize="13sp"
                android:textColor="#636E72"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F2F6"
                android:layout_marginVertical="8dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>