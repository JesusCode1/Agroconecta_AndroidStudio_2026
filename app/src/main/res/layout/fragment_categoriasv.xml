<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Vendedor.N_F_vendedor.FragmentCategoriasv">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgCategoria"
            android:src="@drawable/ico_foto"
            android:layout_marginTop="15dp"
            android:layout_width="100dp"
            android:layout_gravity="center"
            android:layout_height="100dp"/>


        <!--Nombre categoria-->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp">
            <EditText
                android:id="@+id/tCategoria"
                android:hint="@string/tCategoria"
                android:inputType="textCapWords"
                android:enabled="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregarCat"
            android:text="@string/btnAgregarCat"
            app:cornerRadius="8dp"
            android:enabled="false"
            android:textAllCaps="true"
            android:layout_marginTop="15dp"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!--Lista de categorias-->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategoria"
            tools:listitem="@layout/categoriav"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            />
    </androidx.appcompat.widget.LinearLayoutCompat>

</RelativeLayout>