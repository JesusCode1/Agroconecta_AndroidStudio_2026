<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Vendedor.N_F_vendedor.Fragment_iniciov">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/bfragment"
        android:layout_marginBottom="80dp"/>

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/btnAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:contentInsetEnd="0dp"
        app:contentInsetStart="0dp"
        app:fabCradleMargin="10dp"
        app:fabAlignmentMode="center"
        app:fabCradleRoundedCornerRadius="20dp"
        >
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/btnNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/transparent"
            android:elevation="0dp"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/botton_nav_bar_vendedor_menu"/>

    </com.google.android.material.bottomappbar.BottomAppBar>
   <com.google.android.material.floatingactionbutton.FloatingActionButton
       android:id="@+id/FloatB"
       android:backgroundTint="@color/verde_claro"
       android:src="@drawable/ico_add"
       android:layout_marginBottom="30dp"
       app:layout_anchor="@id/btnAppBar"
       app:tint="@android:color/white"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"/>
    
</androidx.coordinatorlayout.widget.CoordinatorLayout>