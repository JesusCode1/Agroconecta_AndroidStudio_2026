<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="10dp"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <!--Id orden-->
        <TextView
            android:id="@+id/idOrdenItem"
            android:text="id orden"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <!--Fecha orden-->
        <TextView
            android:id="@+id/fechaOrdenItem"
            android:layout_toStartOf="@+id/ibSiguiente"
            android:text="00/00/0000"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <!--Estado orden-->
        <TextView
            android:id="@+id/estadoOrdenItem"
            android:text="Estado"
            android:layout_below="@+id/fechaOrdenItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <!--Costo orden-->
        <TextView
            android:id="@+id/costoOrdenItem"
            android:text="00"
            android:layout_below="@+id/estadoOrdenItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ImageButton
            android:id="@+id/ibSiguiente"
            android:src="@drawable/ico_siguiente"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>



    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>